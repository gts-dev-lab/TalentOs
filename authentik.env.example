# ===== AUTHENTIK SSO - CONFIGURACIÓN =====
# Copiar este archivo a .env.authentik y configurar los valores

# ===== SECRETOS (GENERAR NUEVOS) =====
# Generar con: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=CAMBIAR-POR-SECRET-GENERADO-CON-OPENSSL

# Generar con: openssl rand -base64 36
PG_PASS=CAMBIAR-POR-PASSWORD-POSTGRES-GENERADO

# ===== URLs =====
# Desarrollo
AUTHENTIK_URL=http://localhost:9000

# Producción (descomentar y configurar)
# AUTHENTIK_URL=https://auth.tuempresa.com

# ===== PUERTOS =====
AUTHENTIK_PORT_HTTP=9000
AUTHENTIK_PORT_HTTPS=9443

# ===== EMAIL (OPCIONAL - Configurar después) =====
# Gmail/Google Workspace
AUTHENTIK_EMAIL_HOST=smtp.gmail.com
AUTHENTIK_EMAIL_PORT=587
AUTHENTIK_EMAIL_USERNAME=tu-email@empresa.com
AUTHENTIK_EMAIL_PASSWORD=tu-app-password
AUTHENTIK_EMAIL_USE_TLS=true
AUTHENTIK_EMAIL_FROM=authentik@tuempresa.com

# Outlook/Microsoft 365
# AUTHENTIK_EMAIL_HOST=smtp.office365.com
# AUTHENTIK_EMAIL_PORT=587
# AUTHENTIK_EMAIL_USERNAME=tu-email@outlook.com
# AUTHENTIK_EMAIL_PASSWORD=tu-password
# AUTHENTIK_EMAIL_USE_TLS=true

# SendGrid
# AUTHENTIK_EMAIL_HOST=smtp.sendgrid.net
# AUTHENTIK_EMAIL_PORT=587
# AUTHENTIK_EMAIL_USERNAME=apikey
# AUTHENTIK_EMAIL_PASSWORD=tu-sendgrid-api-key
# AUTHENTIK_EMAIL_USE_TLS=true

# ===== LOGGING =====
AUTHENTIK_LOG_LEVEL=info
# Opciones: debug, info, warning, error

# ===== ERROR REPORTING =====
AUTHENTIK_ERROR_REPORTING=false
# Cambiar a true si quieres enviar errores a Authentik (telemetría)

# ===== NOTAS =====
# 1. NO COMMITEAR ESTE ARCHIVO CON VALORES REALES
# 2. Asegurar que .env.authentik está en .gitignore
# 3. Generar secretos únicos para cada instalación
# 4. En producción, usar URLs HTTPS
